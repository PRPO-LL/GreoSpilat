# Template for greo-spilat/.env — copy to .env and fill in real values.
# .env is gitignored and must never be committed.

# --- database ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=events_users
DB_USERNAME=changeme
DB_PASSWORD=changeme

# --- service ports & internal URLs (Docker-network hostnames) ---
AUTH_SERVICE_PORT=8085
AUTH_API_URL=http://auth-service:8085/v1

USER_SERVICE_PORT=8084
USER_API_URL=http://user-service:8084/v1

EVENT_SERVICE_PORT=8083
EVENT_API_URL=http://event-service:8083/v1

NOTIFICATIONS_SERVICE_PORT=8401
NOTIFICATIONS_API_URL=http://notifications-service:8401/v1

COMMENTS_SERVICE_PORT=8402
COMMENTS_API_URL=http://comments-service:8402/v1

JOIN_SERVICE_PORT=8403
JOIN_API_URL=http://join-service:8403/v1
